// .env
# App
APP_PORT=8080
APP_ENV=development
# Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gin_app
# JWT Secret (gunakan string random yang panjang)
JWT_SECRET=1234567890abcdef1234567890abcdef
JWT_EXPIRE_HOURS=24
# Firebase Service Account Key Path
# Download dari: Firebase Console -> Project Settings -> Service Accounts
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json